{
  "name": "k8s-env-diff",
  "version": "1.0.15",
  "description": "Compare Kubernetes application environment variables across clusters",
  "author": {
    "name": "Toan Truyen",
    "email": "truyenminhtoan@gmail.com"
  },
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/toantruyen-ai/diff-app.git"
  },
  "scripts": {
    "build:renderer": "esbuild renderer/app.js --bundle --format=iife --platform=browser --outfile=renderer/dist/app.js",
    "prestart": "node scripts/patch-electron-name.js && npm run build:renderer",
    "start": "electron .",
    "predev": "node scripts/patch-electron-name.js && npm run build:renderer",
    "dev": "electron . --dev",
    "test": "vitest run",
    "prebuild:mac": "npm run build:renderer",
    "build:mac": "electron-builder --mac",
    "prebuild:linux": "npm run build:renderer",
    "build:linux": "electron-builder --linux",
    "prebuild:all": "npm run build:renderer",
    "build:all": "electron-builder --mac --linux"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "diff": "^5.2.2",
    "electron-updater": "^6.8.9",
    "mssql": "^11.0.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.devops.diff-app",
    "productName": "Diff-App",
    "publish": {
      "provider": "github",
      "owner": "toantruyen-ai",
      "repo": "diff-app",
      "releaseType": "release"
    },
    "icon": "build/icon",
    "files": [
      "main.js",
      "preload.js",
      "logo.png",
      "build/icon.png",
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    }
  }
}
