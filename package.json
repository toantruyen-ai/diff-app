{
  "name": "k8s-env-diff",
  "version": "1.0.0",
  "description": "Compare Kubernetes application environment variables across clusters",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/OWNER/REPO.git"
  },
  "scripts": {
    "prestart": "node scripts/patch-electron-name.js",
    "start": "electron .",
    "predev": "node scripts/patch-electron-name.js",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --linux"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.devops.diff-app",
    "productName": "Diff App",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "icon": "build/icon",
    "files": [
      "main.js",
      "preload.js",
      "logo.png",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    }
  }
}
