{
  "name": "k8s-env-diff",
  "version": "1.0.0",
  "description": "Compare Kubernetes application environment variables across clusters",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --linux"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.devops.k8s-env-diff",
    "productName": "K8s ENV Diff",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "deb": {
      "depends": ["libnotify4", "libxtst6", "libnss3"]
    }
  }
}
